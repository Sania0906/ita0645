# Perceptron for 2-class Iris

X = [[5.1,1.4],[6.2,4.5],[4.9,1.4],[5.9,4.2]]
y = [0,1,0,1]

w = [0,0]
bias = 0
lr = 0.1

for epoch in range(10):
    for i in range(len(X)):
        s = w[0]*X[i][0] + w[1]*X[i][1] + bias
        output = 1 if s > 0 else 0
        error = y[i] - output
        w[0] += lr * error * X[i][0]
        w[1] += lr * error * X[i][1]
        bias += lr * error

print("Weights:", w)
print("Bias:", bias)
