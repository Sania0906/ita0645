# Simple Perceptron

X = [[0,0],[0,1],[1,0],[1,1]]
y = [0,0,0,1]   # AND Gate

w = [0,0]
bias = 0
lr = 0.1

for epoch in range(10):
    for i in range(len(X)):
        s = w[0]*X[i][0] + w[1]*X[i][1] + bias
        output = 1 if s > 0 else 0
        error = y[i] - output
        w[0] += lr * error * X[i][0]
        w[1] += lr * error * X[i][1]
        bias += lr * error

print("Weights:", w)
print("Bias:", bias)
